# Mock mode (default) lets the app run with no Zone credentials.
USE_MOCK=true

# To call Zone's real test endpoint, set USE_MOCK=false and provide the key.
# (The sample test key below is from Zone's public docs and may be expired.)
ZONE_BASE_URL=https://devagency.appzonegroup.com
ZONE_API_KEY=ft_3592334282594906488

# Observability - leave blank locally, set this in the cloud deployment.
APPLICATIONINSIGHTS_CONNECTION_STRING=
